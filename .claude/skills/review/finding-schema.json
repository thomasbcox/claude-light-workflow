{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "summary": {
      "type": "string",
      "description": "One-paragraph overall assessment of the change."
    },
    "findings": {
      "type": "array",
      "description": "Empty array if there are no issues.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "severity": {
            "type": "string",
            "enum": ["BLOCKER", "IMPORTANT", "QUESTION", "NIT"]
          },
          "title": { "type": "string", "description": "Short label for the finding." },
          "file": { "type": ["string", "null"], "description": "Path the finding is about, or null." },
          "line": { "type": ["integer", "null"], "description": "Line number, or null." },
          "claim": { "type": "string", "description": "What is wrong and why it matters." },
          "suggestion": { "type": ["string", "null"], "description": "Concrete proposed fix, or null." }
        },
        "required": ["severity", "title", "file", "line", "claim", "suggestion"]
      }
    }
  },
  "required": ["summary", "findings"]
}
